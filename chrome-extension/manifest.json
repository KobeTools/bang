{
  "manifest_version": 3,
  "name": "Bang",
  "version": "1.0.0",
  "description": "Redirect !bang searches after Enter while keeping your default search engine autocomplete.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Bang",
    "default_popup": "popup.html"
  },
  "options_page": "options.html",
  "permissions": [
    "tabs",
    "storage",
    "webNavigation"
  ]
}
